# ============================================================================
# Acceso Remoto (Apache Guacamole) — copia estas variables a tu .env real
# ============================================================================

# Clave AES-256 para cifrar el token de conexión (protocolo + credenciales).
# Genera una con:  openssl rand -hex 32   (deben ser EXACTAMENTE 32 bytes hex)
GUAC_TOKEN_KEY=

# Demonio guacd (corre en el mismo servidor, escuchando solo en loopback).
GUACD_HOST=127.0.0.1
GUACD_PORT=4822

# Destino al que guacd se conecta (localhost porque guacd vive en el mismo host).
REMOTE_HOST=127.0.0.1

# --- VNC (escritorio Xorg vía x11vnc en :0) ---
REMOTE_VNC_PORT=5901
REMOTE_VNC_PASSWORD=

# --- SSH (terminal) ---
REMOTE_SSH_PORT=22
REMOTE_SSH_USER=
REMOTE_SSH_PASSWORD=

# ============================================================================
# Frontend (D:\PMY\app-pmy/.env): la URL del WSS se deriva de NEXT_PUBLIC_API_URL
# (http→ws / https→wss). No requiere variable nueva.
# ============================================================================

# ============================================================================
# Respaldo producción → MySQL local (Configuración → Servidor → Respaldo)
# ============================================================================

# Secreto compartido entre PROD y tu backend LOCAL. Autoriza el endpoint de
# dump server-to-server. Genera uno con:  openssl rand -hex 32
# Debe ser el MISMO valor en el .env de producción y en tu .env local.
BACKUP_SECRET=

# --- Solo en tu .env LOCAL (dev) ---

# Habilita el restore local. Sin este flag (o en producción) el restore se
# rechaza siempre. Nunca lo pongas en el .env de producción.
BACKUP_ALLOW_RESTORE=1

# API de producción (dominio estable) de donde se trae el dump. Este es el
# default, solo cámbialo si tu dominio es otro.
PROD_API_URL=https://api.paqueteriaymensajeriadelyaqui.com/api

# Rutas a los binarios de MySQL si NO están en el PATH (opcional).
# En prod se usa mysqldump; en local, el cliente mysql. Ejemplo Windows:
# MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysql.exe
# MYSQLDUMP_BIN=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
MYSQLDUMP_BIN=
MYSQL_BIN=
