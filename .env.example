# ============================================================================
# Acceso Remoto (Apache Guacamole) — copia estas variables a tu .env real
# ============================================================================

# Clave AES-256 para cifrar el token de conexión (protocolo + credenciales).
# Genera una con:  openssl rand -hex 32   (deben ser EXACTAMENTE 32 bytes hex)
GUAC_TOKEN_KEY=

# Demonio guacd (corre en el mismo servidor, escuchando solo en loopback).
GUACD_HOST=127.0.0.1
GUACD_PORT=4822

# Destino al que guacd se conecta (localhost porque guacd vive en el mismo host).
REMOTE_HOST=127.0.0.1

# --- VNC (escritorio Xorg vía x11vnc en :0) ---
REMOTE_VNC_PORT=5901
REMOTE_VNC_PASSWORD=

# --- SSH (terminal) ---
REMOTE_SSH_PORT=22
REMOTE_SSH_USER=
REMOTE_SSH_PASSWORD=

# ============================================================================
# Frontend (D:\PMY\app-pmy/.env): la URL del WSS se deriva de NEXT_PUBLIC_API_URL
# (http→ws / https→wss). No requiere variable nueva.
# ============================================================================
